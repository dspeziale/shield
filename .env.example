# ============================================================
#  hermes-ids — Variabili d'ambiente
#  cp .env.example .env  → poi modifica i valori
#  NON committare .env su git!
# ============================================================

# ── Interfaccia di rete da monitorare ────────────────────────
# Lista interfacce disponibili: ip link show
# Esempi: eth0, wlan0, ens3, enp3s0
CAPTURE_INTERFACE=eth0

# ── Hermes Gateway ───────────────────────────────────────────
# URL del gateway Hermes (deve essere raggiungibile dal container)
# Stessa macchina: http://127.0.0.1:8644
# Host remoto:     http://192.168.1.X:8644
HERMES_GATEWAY_URL=http://127.0.0.1:8644

# ── Secrets webhook (da webhook_subscriptions.json in Hermes) ─
# Secret per "ids-events"  → alert real-time
HERMES_EVENTS_SECRET=

# Secret per "ids-report"  → report periodici Telegram
HERMES_REPORT_SECRET=

# ── Report periodico ─────────────────────────────────────────
# Intervallo secondi tra i report Telegram (600 = 10 minuti)
HERMES_REPORT_INTERVAL=600

# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
